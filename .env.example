# GitHub API: use a Personal Access Token (classic or fine-grained).
# https://github.com/settings/tokens
GITHUB_TOKEN=your-token-here
# GitHub username for GraphQL pinned repositories (public login handle).
GITHUB_LOGIN=your-github-username

# Resume: public HTTPS URL from Vercel Blob (Storage → upload PDF → copy URL).
# 1) Vercel project → Storage → Blob store attached to this project
# 2) Upload ChuongTran_Resume.pdf (public access)
# 3) Paste URL below; also set in Vercel → Settings → Environment Variables
# Leave empty to use /ChuongTran_Resume.pdf from public/
NEXT_PUBLIC_RESUME_URL=your-resume-url-here
